# Test files use literal path segments under hardened helpers (joinUnderRoot,
# resolvePathUnderProjectRoot). Static path-injection rules fire false positives
# on every fs.* call; the same exclusion is already in .codacy.yaml.
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
packages/**/__tests__/**

# Dev-only build/scripts: paths come from the monorepo's own config.
scripts/
packages/cli/scripts/

# CLI scaffold templates: copied into generated projects, not run here.
packages/cli/template-sources/
