{
  "name": "@cyberfabric/screensets",
  "version": "0.2.0-alpha.3",
  "description": "Pure TypeScript contracts and registry for FrontX screenset management",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./plugins/gts": {
      "types": "./dist/mfe/plugins/gts/index.d.ts",
      "import": "./dist/mfe/plugins/gts/index.js",
      "require": "./dist/mfe/plugins/gts/index.cjs"
    },
    "./mfe/handler": {
      "types": "./dist/mfe/handler/index.d.ts",
      "import": "./dist/mfe/handler/index.js",
      "require": "./dist/mfe/handler/index.cjs"
    },
    "./build/mf-gts": {
      "types": "./dist/build/mf-gts.d.ts",
      "import": "./dist/build/mf-gts.js",
      "require": "./dist/build/mf-gts.cjs"
    }
  },
  "files": [
    "dist",
    "CLAUDE.md",
    "llms.txt"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "type-check:test": "tsc -p tsconfig.test.json",
    "test": "npm run test:unit",
    "test:unit": "vitest --run --passWithNoTests=false",
    "test:unit:watch": "vitest --watch"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.4",
    "tsup": "^8.0.0",
    "typescript": "^5.4.2",
    "vitest": "4.1.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "frontx",
    "screensets",
    "contracts",
    "typescript",
    "vertical-slices"
  ],
  "author": "Cyber Fabric",
  "license": "Apache-2.0",
  "dependencies": {
    "@globaltypesystem/gts-ts": "^0.3.0"
  },
  "peerDependencies": {
    "esbuild": ">=0.20.0",
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "esbuild": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  }
}
