{
  "name": "@cyberfabric/i18n",
  "version": "0.2.0-alpha.1",
  "description": "Internationalization and translation management for FrontX SDK",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    }
  },
  "files": [
    "dist",
    "CLAUDE.md",
    "llms.txt"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "type-check:test": "tsc -p tsconfig.test.json",
    "test": "npm run test:unit",
    "test:unit": "vitest --run --passWithNoTests=false",
    "test:unit:watch": "vitest --watch"
  },
  "dependencies": {},
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.4",
    "tsup": "^8.0.0",
    "typescript": "^5.4.2",
    "vitest": "4.1.4"
  },
  "peerDependencies": {},
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "frontx",
    "i18n",
    "internationalization",
    "localization",
    "typescript"
  ],
  "author": "Cyber Fabric",
  "license": "Apache-2.0"
}
